print("BoneHub Loaded")

-- SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local MarketplaceService = game:GetService("MarketplaceService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

-- GAMEPASS BYPASS
pcall(function()
    hookfunction(MarketplaceService.UserOwnsGamePassAsync,function()
        return true
    end)
end)

-- VARIABLES
local jumpHeight = 50
local infiniteJump = false
local autoJump = false
local espEnabled = false
local vipRemoved = false
local minimized = false
local MinFrame

-- INFINITE JUMP
UIS.JumpRequest:Connect(function()
    if infiniteJump then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

-- AUTO JUMP
RunService.RenderStepped:Connect(function()
    if autoJump and humanoid.FloorMaterial ~= Enum.Material.Air then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

-- APPLY JUMP HEIGHT
RunService.RenderStepped:Connect(function()
    humanoid.JumpPower = jumpHeight
end)

-- ESP SYSTEM
local function addESP(plr)

    if plr == player then return end

    local function apply(char)

        if char:FindFirstChild("BoneHubESP") then return end

        local h = Instance.new("Highlight")
        h.Name = "BoneHubESP"
        h.FillColor = Color3.fromRGB(255,0,0)
        h.OutlineColor = Color3.fromRGB(255,255,255)
        h.FillTransparency = 0.5
        h.Parent = char

    end

    if plr.Character then
        apply(plr.Character)
    end

    plr.CharacterAdded:Connect(apply)

end

local function removeESP()

    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("Highlight") and v.Name == "BoneHubESP" then
            v:Destroy()
        end
    end

end

-- VIP WALL REMOVER
local function removeVIP()

    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then

            local name = string.lower(v.Name)

            if string.find(name,"vip") then
                v.CanCollide = false
                v.Transparency = 1
            end

        end
    end

end

-- GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui
ScreenGui.Name = "ETFB BoneHub"

local Frame = Instance.new("Frame")
Frame.Parent = ScreenGui
Frame.Size = UDim2.new(0,330,0,330)
Frame.Position = UDim2.new(0.5,-165,0.5,-165)
Frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
Frame.Active = true
Frame.Draggable = true

-- TITLE
local Title = Instance.new("TextLabel")
Title.Parent = Frame
Title.Size = UDim2.new(1,0,0,30)
Title.BackgroundTransparency = 1
Title.Text = "BoneHub"
Title.TextColor3 = Color3.new(1,1,1)
Title.Font = Enum.Font.SourceSansBold
Title.TextSize = 20

-- BUTTON MAKER
local function makeButton(text,y)

    local b = Instance.new("TextButton")
    b.Parent = Frame
    b.Size = UDim2.new(0,300,0,35)
    b.Position = UDim2.new(0,15,0,y)
    b.BackgroundColor3 = Color3.fromRGB(50,50,50)
    b.TextColor3 = Color3.new(1,1,1)
    b.Text = text

    return b
end

-- INFINITE JUMP BUTTON
local IJ = makeButton("Infinite Jump: OFF",40)

IJ.MouseButton1Click:Connect(function()

    infiniteJump = not infiniteJump
    IJ.Text = "Infinite Jump: "..(infiniteJump and "ON" or "OFF")

end)

-- AUTO JUMP BUTTON
local AJ = makeButton("Auto Jump: OFF",80)

AJ.MouseButton1Click:Connect(function()

    autoJump = not autoJump
    AJ.Text = "Auto Jump: "..(autoJump and "ON" or "OFF")

end)

-- ESP BUTTON
local ESP = makeButton("ESP: OFF",120)

ESP.MouseButton1Click:Connect(function()

    espEnabled = not espEnabled

    if espEnabled then
        ESP.Text = "ESP: ON"

        for _,p in pairs(Players:GetPlayers()) do
            addESP(p)
        end

    else

        ESP.Text = "ESP: OFF"
        removeESP()

    end

end)

-- DUPE BUTTON
local Dupe = makeButton("Dupe Tool",160)

Dupe.MouseButton1Click:Connect(function()

    local char = player.Character
    if not char then return end

    local tool = char:FindFirstChildOfClass("Tool")

    if tool then
        tool:Clone().Parent = player.Backpack
    end

end)

-- VIP BUTTON
local VIP = makeButton("VIP WALLS: OFF",200)

VIP.MouseButton1Click:Connect(function()

    vipRemoved = not vipRemoved

    if vipRemoved then

        VIP.Text = "VIP WALLS: ON"
        removeVIP()

    else

        VIP.Text = "VIP WALLS: OFF"

    end

end)

-- JUMP HEIGHT BOX
local JumpBox = Instance.new("TextBox")
JumpBox.Parent = Frame
JumpBox.Size = UDim2.new(0,300,0,30)
JumpBox.Position = UDim2.new(0,15,0,240)
JumpBox.BackgroundColor3 = Color3.fromRGB(50,50,50)
JumpBox.TextColor3 = Color3.new(1,1,1)
JumpBox.Text = "Jump Height: 50"

JumpBox.FocusLost:Connect(function()

    local val = tonumber(JumpBox.Text)

    if val and val >= 50 and val <= 500 then
        jumpHeight = val
    end

end)

-- MINIMIZE BUTTON
local Min = Instance.new("TextButton")
Min.Parent = Frame
Min.Size = UDim2.new(0,30,0,30)
Min.Position = UDim2.new(1,-35,0,5)
Min.Text = "-"

-- CLOSE
local Close = Instance.new("TextButton")
Close.Parent = Frame
Close.Size = UDim2.new(0,30,0,30)
Close.Position = UDim2.new(1,-70,0,5)
Close.Text = "X"

-- MINIMIZE FUNCTION
Min.MouseButton1Click:Connect(function()

    if minimized then return end

    Frame.Visible = false
    minimized = true

    MinFrame = Instance.new("TextButton")
    MinFrame.Parent = ScreenGui
    MinFrame.Size = UDim2.new(0,50,0,50)
    MinFrame.Position = Frame.Position
    MinFrame.Text = "BH"
    MinFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    MinFrame.TextColor3 = Color3.new(1,1,1)
    MinFrame.Active = true
    MinFrame.Draggable = true

    MinFrame.MouseButton1Click:Connect(function()

        Frame.Position = MinFrame.Position
        MinFrame:Destroy()

        Frame.Visible = true
        minimized = false

    end)

end)

-- CLOSE FUNCTION
Close.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)
